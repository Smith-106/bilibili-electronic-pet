{
  "name": "bili-pet-backend-ts",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Bilibili Electronic Pet Backend - TypeScript Migration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "lint": "echo 'Add linter configuration'",
    "format": "echo 'Add formatter configuration'",
    "clean": "rm -rf dist node_modules coverage prisma/dev.db prisma/test.db",
    "reinstall": "npm run clean && npm install",
    "docker:build": "docker build -t bilibili-pet-backend:latest .",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "deploy": "bash deploy.sh all",
    "deploy:docker": "bash deploy.sh deploy"
  },
  "keywords": [
    "bilibili",
    "backend",
    "typescript",
    "fastify",
    "prisma",
    "bullmq"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.71.1",
    "dotenv": "^16.3.1",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^7.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
