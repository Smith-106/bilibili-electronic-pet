# Node.js
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bilibili_pet?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Worker Configuration
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF=2
WORKER_RETRY_JITTER=true

# Application
KILL_SWITCH=false
ROLE_PROFILE_DEFAULT=doro

# API Authentication
API_KEY=                     # Admin API key (x-api-key header)

# Gateway Authentication
GATEWAY_TOKEN=                # Gateway publish token
GATEWAY_HMAC_SECRET=          # Gateway HMAC signature secret

# Reply Decision Configuration
REPLY_BASE_PROBABILITY=0.7
REPLY_COOLDOWN_MINUTES=5
REPLY_QUIET_HOURS_START=23
REPLY_QUIET_HOURS_END=7

REPLY_ROLE_PROFILE_DEFAULT=doro

REPLY_LENGTH_MODE_DEFAULT=medium


# Safety Check Configuration
SAFETY_SENSITIVITY_LEVEL=medium  # low | medium | high



# API Keys (if needed)
# OPENAI_API_KEY=sk-...
# BILIBILI_SESSDATA=...
# BILIBILI_BILI_JCT=...

# ============================================================
# LLM Configuration (Phase 2)
# ============================================================
LLM_PROVIDER=openai           # openai | claude | ollama
LLM_API_KEY=                  # Required for openai/claude
LLM_MODEL=gpt-4               # Model name for the provider
LLM_BASE_URL=                  # Custom base URL (optional)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=150
LLM_TIMEOUT=30000
LLM_RETRIES=2

# ============================================================
# Bilibili API Configuration (Phase 3)
# ============================================================
BILIBILI_SESSDATA=                # Bilibili session cookie
BILIBILI_BILI_JCT=                # Bilibili CSRF token
BILIBILI_BUVID3=                  # Bilibili BUVID cookie
BILIBILI_DEDEUSERID=              # Bilibili user ID
BILIBILI_BASE_URL=https://api.bilibili.com
BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
BILIBILI_TIMEOUT=30000
BILIBILI_RETRIES=3

# ============================================================
# Search Configuration (Phase 4)
# ============================================================
SEARCH_PROVIDER=serpapi         # serpapi | bing | google
SEARCH_API_KEY=                 # Required for search provider
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=10000
SEARCH_CX=                      # Google Custom Search CX (Google only)
