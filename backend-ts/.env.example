# Node.js
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL="file:./dev.db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Worker Configuration
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF=2
WORKER_RETRY_JITTER=true

# Application
KILL_SWITCH=false
ROLE_PROFILE_DEFAULT=doro

# API Authentication
API_KEY=                     # Admin API key (x-api-key header)

# Gateway Authentication
GATEWAY_TOKEN=                # Gateway publish token
GATEWAY_HMAC_SECRET=          # Gateway HMAC signature secret

# Reply Decision Configuration
REPLY_BASE_PROBABILITY=0.7
REPLY_COOLDOWN_MINUTES=5
REPLY_QUIET_HOURS_START=23
REPLY_QUIET_HOURS_END=7

REPLY_ROLE_PROFILE_DEFAULT=doro

REPLY_LENGTH_MODE_DEFAULT=medium

# ============================================================
# Safety Check Configuration
# ============================================================
SAFETY_SENSITIVITY_LEVEL=medium  # low | medium | high
SAFETY_ENABLE_KEYWORD_BLACKLIST=true
SAFETY_KEYWORD_BLACKLIST=政治,仇恨,身份证,手机号,去死
SAFETY_ENABLE_PII_DETECTION=true
SAFETY_PII_ACTION=manual_queue    # manual_queue | blocked
SAFETY_MAX_REPLY_CHARS=900

# ============================================================
# Publisher Configuration
# ============================================================
PUBLISHER_MODE=manual_queue       # manual_queue | simulated | webhook | real_publish
PUBLISHER_WEBHOOK_URL=            # Webhook URL (webhook mode only)
PUBLISHER_WEBHOOK_TOKEN=          # Webhook auth token (webhook mode only)
PUBLISHER_TIMEOUT_SECONDS=15
PUBLISHER_HMAC_SECRET=
PUBLISHER_CIRCUIT_BREAKER_ENABLED=true
PUBLISHER_CIRCUIT_FAILURE_THRESHOLD=3
PUBLISHER_CIRCUIT_OPEN_SECONDS=30

# ============================================================
# LLM Configuration
# ============================================================
LLM_PROVIDER=openai           # openai | claude | ollama
LLM_API_KEY=                  # Required for openai/claude
LLM_MODEL=gpt-4               # Model name for the provider
LLM_BASE_URL=                  # Custom base URL (optional)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=150
LLM_TIMEOUT=30000
LLM_RETRIES=2
LLM_FALLBACK_TO_MOCK=true   # Use Doro mock replies when LLM fails

# ============================================================
# Bilibili API Configuration
# ============================================================
BILIBILI_SESSDATA=                # Bilibili session cookie
BILIBILI_BILI_JCT=                # Bilibili CSRF token
BILIBILI_BUVID3=                  # Bilibili BUVID cookie
BILIBILI_DEDEUSERID=              # Bilibili user ID
BILIBILI_BASE_URL=https://api.bilibili.com
BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
BILIBILI_TIMEOUT=30000
BILIBILI_RETRIES=3

# ============================================================
# Platform Configuration
# ============================================================
PLATFORM_BILIBILI_ENABLED=true
PLATFORM_DOUYIN_ENABLED=false
PLATFORM_KUAISHOU_ENABLED=false
PLATFORM_BILIBILI_PUBLISH_SOURCE=bilibili-bot
PLATFORM_DOUYIN_PUBLISH_SOURCE=douyin-bot
PLATFORM_KUAISHOU_PUBLISH_SOURCE=kuaishou-bot

# ============================================================
# Knowledge Configuration
# ============================================================
KNOWLEDGE_ENABLED=true
KNOWLEDGE_MAX_HITS=3

# ============================================================
# Search Configuration
# ============================================================
SEARCH_PROVIDER=serpapi         # serpapi | bing | google
SEARCH_API_KEY=                 # Required for search provider
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=10000
SEARCH_CX=                      # Google Custom Search CX (Google only)
SEARCH_ALLOWED_DOMAINS=        # Comma-separated domain whitelist (optional)

# ============================================================
# Style / Role Configuration
# ============================================================
STYLE_PROFILE_DEFAULT=auto   # auto | empathy | meme | normal
