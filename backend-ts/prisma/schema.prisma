// Prisma Schema for TypeScript Backend
// Migrated from Python SQLAlchemy models
// SQLite-compatible schema (no native type annotations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Comment {
  id                  Int      @id @default(autoincrement())
  platform            String   @default("bilibili")
  canonical_comment_id String   @unique
  comment_id          String
  video_id            String
  user_id             String
  content             String
  parent_id           String?
  created_at          DateTime @default(now())

  @@index([platform])
  @@index([canonical_comment_id])
  @@index([comment_id])
  @@map("comments")
}

model ReplyJob {
  id                  Int      @id @default(autoincrement())
  comment_id          String
  canonical_comment_id String?
  status              String   @default("queued")
  length_mode         String   @default("medium")
  style_mode          String   @default("doro")
  reply_text          String?
  risk_flags          String   @default("{}")
  attempts            Int      @default(0)
  published_at        DateTime?
  created_at          DateTime @default(now())

  @@index([comment_id])
  @@index([canonical_comment_id])
  @@index([status])
  @@index([created_at])
  @@index([status, created_at, id])
  @@map("reply_jobs")
}

model UserState {
  id              Int      @id @default(autoincrement())
  user_id         String   @unique
  recent_phrases  String   @default("{}")
  cooldown_enabled Boolean @default(false)
  updated_at      DateTime @default(now())

  @@map("user_state")
}

model PublishLog {
  id                  Int      @id @default(autoincrement())
  platform            String   @default("bilibili")
  reservation_key     String?  @unique
  canonical_comment_id String
  comment_id          String
  reply_hash          String
  source              String   @default("bili-pet-bot")
  status              String   @default("published")
  published_at        DateTime?
  failure_reason      String?
  created_at          DateTime @default(now())

  @@unique([canonical_comment_id, reply_hash], name: "uq_publish_logs_canonical_reply")
  @@index([platform])
  @@index([canonical_comment_id])
  @@index([comment_id])
  @@index([status])
  // PERF-001: STAGE_DAILY_QUOTA count 热路径 where (source, status, published_at>=startOfDay) 复合索引.
  @@index([source, status, published_at])
  @@map("publish_logs")
}

model CommentQueueBacklog {
  id                  Int      @id @default(autoincrement())
  platform            String   @default("bilibili")
  canonical_comment_id String   @unique
  comment_id          String
  source              String   @default("webhook")
  payload_json        String   @default("{}")
  status              String   @default("pending_requeue")
  last_error          String?
  queue_attempts      Int      @default(0)
  last_attempt_at     DateTime?
  recovered_at        DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())

  @@index([status])
  @@index([created_at])
  @@index([updated_at])
  @@map("comment_queue_backlogs")
}

model KnowledgeEntry {
  id         Int      @id @default(autoincrement())
  category   String
  title      String
  content    String
  enabled    Boolean  @default(true)
  updated_at DateTime @default(now())

  @@index([category])
  @@index([enabled])
  @@index([updated_at])
  @@map("knowledge_entries")
}

model RoleCard {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  name          String
  description   String   @default("")
  system_prompt String   @default("")
  tone          String   @default("{}")
  constraints   String   @default("{}")
  enabled       Boolean  @default(true)
  is_active     Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  @@index([key])
  @@index([enabled])
  @@index([is_active])
  @@map("role_cards")
}

model OperationAuditLog {
  id          Int      @id @default(autoincrement())
  action      String
  target_type String   @default("reply_job")
  target_id   Int?
  payload     String   @default("{}")
  ok          Boolean  @default(true)
  created_at  DateTime @default(now())

  @@index([action])
  @@index([target_id])
  @@index([ok])
  @@index([created_at])
  @@index([action, ok, created_at, id])
  @@index([target_id, created_at, id])
  @@map("operation_audit_logs")
}

model ObservabilityEvent {
  id           Int      @id @default(autoincrement())
  event_type   String
  trace_id     String
  comment_id   String?
  job_id       Int?
  status       String?
  duration_ms  Int?
  event_metadata String @default("{}")
  // L2: Antirisk signal subclass (-352 behavior_anomaly / -429 rate_limit).
  // Indexed for online eval groupBy aggregation (Decision 2 rejected JSON).
  error_subclass String?
  // L2: Optional persona linkage for antirisk signal attribution.
  persona_id     String?
  created_at   DateTime @default(now())

  @@index([event_type])
  @@index([trace_id])
  @@index([comment_id])
  @@index([job_id])
  @@index([status])
  @@index([created_at])
  @@index([error_subclass])
  // PERF-002: behavior_anomaly count 查询 where (error_subclass, created_at>=windowStart) 复合索引,
  // 避免 full scan over error_subclass 行 (isBehaviorAnomalyCountZero readiness gate 热路径).
  @@index([error_subclass, created_at])
  @@map("observability_events")
}

model BilibiliCredential {
  id           Int       @id @default(autoincrement())
  name         String
  sessdata     String    // Encrypted storage
  bili_jct     String    // Encrypted storage
  buvid3       String
  buvid4       String?
  is_active    Boolean   @default(true)
  expires_at   DateTime?
  last_used_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  @@index([is_active])
  @@index([updated_at])
  @@map("bilibili_credentials")
}

model BilibiliVideo {
  id               Int       @id @default(autoincrement())
  bvid             String    @unique
  aid              Int?
  title            String?
  owner_mid        Int?
  poll_enabled     Boolean   @default(false)
  last_polled_at   DateTime?
  last_poll_status String?
  last_poll_error  String?
  last_rpid        Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  @@index([poll_enabled, last_polled_at])
  @@index([last_polled_at])
  @@index([updated_at])
  @@map("bilibili_videos")
}

model MemorySpace {
  id         Int      @id @default(autoincrement())
  space_key  String   @unique
  space_type String   @default("operator")
  title      String
  summary    String   @default("")
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  items  MemoryItem[]
  grants MemoryGrant[]

  @@index([space_type])
  @@index([updated_at])
  @@map("memory_spaces")
}

model MemoryItem {
  id            Int      @id @default(autoincrement())
  space_id      Int
  item_key      String
  content       String
  content_type  String   @default("note")
  source        String   @default("operator")
  item_metadata String   @default("{}")
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  space MemorySpace @relation(fields: [space_id], references: [id], onDelete: Cascade)

  @@unique([space_id, item_key], name: "uq_memory_items_space_key")
  @@index([space_id, content_type])
  @@index([updated_at])
  @@map("memory_items")
}

model MemoryGrant {
  id           Int      @id @default(autoincrement())
  space_id     Int
  subject_type String   @default("user")
  subject_id   String
  access_level String   @default("read")
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  space MemorySpace @relation(fields: [space_id], references: [id], onDelete: Cascade)

  @@unique([space_id, subject_type, subject_id], name: "uq_memory_grants_subject")
  @@index([subject_type, subject_id])
  @@index([updated_at])
  @@map("memory_grants")
}

model IdentityLink {
  id           Int      @id @default(autoincrement())
  subject_type String   @default("user")
  subject_id   String
  platform     String   @default("bilibili")
  external_id  String
  display_name String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@unique([platform, external_id], name: "uq_identity_links_platform_external")
  @@index([subject_type, subject_id])
  @@index([updated_at])
  @@map("identity_links")
}

model PetState {
  id                     Int       @id @default(autoincrement())
  profile_key            String    @unique @default("default")
  pet_name               String    @default("Mochi")
  species                String?
  archetype              String?
  mood_label             String    @default("Curious")
  mood_note              String    @default("Settling into the next interaction loop.")
  relationship_level     String    @default("Growing")
  relationship_note      String    @default("Bond is still forming through repeated care actions.")
  progress_stage         String    @default("starter")
  progress_label         String    @default("Starter loop")
  next_milestone         String?
  last_check_in_at       DateTime?
  needs_json             String    @default("[]")
  proactive_signals_json String    @default("[]")
  state_metadata         String    @default("{}")
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now())

  actions PetAction[]

  @@index([updated_at])
  @@map("pet_states")
}

model PetAction {
  id             Int       @id @default(autoincrement())
  profile_key    String    @default("default")
  action         String
  note           String?
  event_detail   String
  state_metadata String    @default("{}")
  created_at     DateTime  @default(now())
  pet_state_id   Int?

  pet_state PetState? @relation(fields: [pet_state_id], references: [id], onDelete: SetNull)

  @@index([profile_key, created_at])
  @@index([pet_state_id, created_at])
  @@map("pet_actions")
}
