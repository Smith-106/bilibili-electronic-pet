# Default TypeScript backend database URL uses a local SQLite/libSQL-style file path.
# Docker Compose services should mount a shared data directory when using containerized SQLite.
# Delivery modes cheat sheet (set env to move between them):
# - Local mock/manual (default): LLM_PROVIDER=mock, PUBLISHER_MODE=manual_queue (no secrets required)
# - Preflight (config-only inspection): provide real secrets in this file; run `npm run staging:check -- --preflight-only --env-file <file>`
# - Strict (runtime + admin): BASE_URL + API_KEY + running API + DB + Redis
# - Webhook delivery: PUBLISHER_MODE=webhook + PUBLISHER_WEBHOOK_URL (+ PUBLISHER_WEBHOOK_TOKEN)
# - Native Bilibili real-chain: BILIBILI_ENABLED=true, BILIBILI_PUBLISH_ENABLED=true, BILIBILI_* credential trio or DB record, CREDENTIAL_ENCRYPTION_KEY
DATABASE_URL=file:./dev.db
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# API readiness summary still reads these compatibility URLs directly.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
KILL_SWITCH=false
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_WAIT_SECONDS=1
LLM_FALLBACK_TO_MOCK=true
# Publisher Configuration
# Precedence (highest to lowest):
# 1. Native Bilibili publisher (when BILIBILI_ENABLED=true AND BILIBILI_PUBLISH_ENABLED=true)
#    - Overrides PUBLISHER_MODE when enabled
#    - Warning logged if PUBLISHER_MODE is webhook/real_publish
# 2. PUBLISHER_MODE setting (manual_queue/simulated/webhook/real_publish)
# 3. ManualQueuePublisher fallback (for unrecognized PUBLISHER_MODE values)
PUBLISHER_MODE=manual_queue
PUBLISHER_WEBHOOK_URL=
PUBLISHER_WEBHOOK_TOKEN=
# real_publish uses the Bilibili runtime credential rather than a separate URL/TOKEN pair.
PUBLISHER_TIMEOUT_SECONDS=15
PUBLISHER_HMAC_SECRET=
GATEWAY_TOKEN=
GATEWAY_HMAC_SECRET=
API_KEY=

# Optional local Douyin sidecar (for docker compose --profile sidecar)
DOUYIN_SIDECAR_TOKEN=replace-with-sidecar-token
DOUYIN_DRIVER_MODE=mock
DOUYIN_UPSTREAM_URL=
DOUYIN_UPSTREAM_TOKEN=

# Staging smoke / rehearsal controls (used by smoke.sh and smoke.ps1 wrappers)
# Equivalent CLI flags:
# - BASE_URL -> --base-url
# - API_KEY -> --api-key
# - ENV_FILE -> --env-file
# - REPORT_PATH -> --report
# - STRICT_SMOKE=true -> --strict
# - PRE_RELEASE_REAL_CHAIN=true -> --pre-release-real-chain (requires strict)
BASE_URL=http://127.0.0.1:18000
ENV_FILE=
REPORT_PATH=
STRICT_SMOKE=false
PRE_RELEASE_REAL_CHAIN=false

# Search enhancement (used by staging-check preflight matrix)
SEARCH_PROVIDER=serpapi
SEARCH_API_KEY=
# Required only when SEARCH_PROVIDER=google
SEARCH_CX=

# Bilibili API Integration
BILIBILI_ENABLED=false
BILIBILI_POLL_ENABLED=false
BILIBILI_POLL_INTERVAL_SECONDS=300
BILIBILI_PUBLISH_ENABLED=false
BILIBILI_CREDENTIAL_ID=1
BILIBILI_RATE_LIMIT_PER_MINUTE=30
BILIBILI_DEDEUSERID=
BILIBILI_BASE_URL=https://api.bilibili.com
BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0
BILIBILI_TIMEOUT=30000
BILIBILI_RETRIES=3
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=
BILIBILI_BUVID4=
CREDENTIAL_ENCRYPTION_KEY=
# Legacy alias accepted for backward compatibility:
# BILIBILI_COOKIE_ENCRYPTION_KEY=

# Multi-platform gateway publishing
PLATFORM_BILIBILI_ENABLED=false
PLATFORM_DOUYIN_ENABLED=false
PLATFORM_KUAISHOU_ENABLED=false
PLATFORM_BILIBILI_WEBHOOK_URL=
PLATFORM_BILIBILI_WEBHOOK_TOKEN=
PLATFORM_DOUYIN_WEBHOOK_URL=
PLATFORM_DOUYIN_WEBHOOK_TOKEN=
PLATFORM_KUAISHOU_WEBHOOK_URL=
PLATFORM_KUAISHOU_WEBHOOK_TOKEN=
PLATFORM_BILIBILI_PUBLISH_SOURCE=bilibili-bot
PLATFORM_DOUYIN_PUBLISH_SOURCE=douyin-bot
PLATFORM_KUAISHOU_PUBLISH_SOURCE=kuaishou-bot
