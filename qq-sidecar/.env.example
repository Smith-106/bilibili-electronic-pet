HOST=0.0.0.0
PORT=8080
# Shared bearer token for POST /publish.
QQ_SIDECAR_TOKEN=replace-with-sidecar-token
# Supported modes: mock | webhook_proxy | onebot_http
# mock is local-only. Production signoff requires webhook_proxy or onebot_http with a verified endpoint.
QQ_DRIVER_MODE=mock
# Used only when QQ_DRIVER_MODE=webhook_proxy
QQ_UPSTREAM_URL=
QQ_UPSTREAM_TOKEN=
# Used only when QQ_DRIVER_MODE=onebot_http
# If qq-sidecar runs in Docker, use an address reachable from the container
# such as http://host.docker.internal:3000 instead of host-only 127.0.0.1.
# The bundled docker-compose.yml already maps host.docker.internal to host-gateway.
QQ_ONEBOT_URL=
QQ_ONEBOT_TOKEN=
