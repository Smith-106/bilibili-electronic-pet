# Expanded-scope preflight example
# This file is for checker-side preflight only.
# It validates that the expanded-scope Douyin trial inputs are present,
# but it does NOT prove the live host can reach the endpoint through WAF/Cloudflare.

DATABASE_URL=file:./dev.db
HOST=127.0.0.1
PORT=18000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
KILL_SWITCH=false

API_KEY=expanded-scope-preflight-key
COMMENT_INGRESS_TOKEN=expanded-scope-comment-ingress-token

LLM_PROVIDER=openai
LLM_API_KEY=local-llm-placeholder
LLM_FALLBACK_TO_MOCK=false
SEARCH_PROVIDER=serpapi
SEARCH_API_KEY=local-search-placeholder

PUBLISHER_MODE=manual_queue
BILIBILI_ENABLED=false
BILIBILI_PUBLISH_ENABLED=false
BILIBILI_POLL_ENABLED=false

PLATFORM_DOUYIN_ENABLED=true
PLATFORM_DOUYIN_WEBHOOK_URL=https://replace-with-verified-douyin-sidecar.example/publish
PLATFORM_DOUYIN_WEBHOOK_TOKEN=replace-with-real-token-if-required
PLATFORM_DOUYIN_PUBLISH_SOURCE=douyin-sidecar-trial

GATEWAY_TOKEN=local-gateway-token
GATEWAY_HMAC_SECRET=local-gateway-hmac-secret
