# Local native real-chain rehearsal example
# This file is a scaffold for pre-release real-chain checks.
# It requires REAL native Bilibili credentials that can pass the runtime auth probe.
# Placeholder values below will not pass.
DATABASE_URL=file:./dev.db
HOST=127.0.0.1
PORT=18000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
KILL_SWITCH=false

API_KEY=real-chain-local-key
COMMENT_INGRESS_TOKEN=replace-with-real-comment-ingress-token

# Keep delivery capabilities configured
LLM_PROVIDER=openai
LLM_API_KEY=replace-with-real-llm-key
LLM_FALLBACK_TO_MOCK=false
SEARCH_PROVIDER=serpapi
SEARCH_API_KEY=replace-with-real-search-key

# Enable native Bilibili publish path
PUBLISHER_MODE=manual_queue
BILIBILI_ENABLED=true
BILIBILI_PUBLISH_ENABLED=true
BILIBILI_POLL_ENABLED=false

# Replace these with REAL values; placeholders will fail the auth probe
BILIBILI_SESSDATA=replace-with-real-sessdata
BILIBILI_BILI_JCT=replace-with-real-bili-jct
BILIBILI_BUVID3=replace-with-real-buvid3
BILIBILI_BUVID4=
CREDENTIAL_ENCRYPTION_KEY=replace-with-real-encryption-key

GATEWAY_TOKEN=local-gateway-token
GATEWAY_HMAC_SECRET=local-gateway-hmac-secret
