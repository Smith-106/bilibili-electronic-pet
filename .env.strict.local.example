# Local strict rehearsal example
# This file is meant for local strict validation only.
# It uses placeholder values that are sufficient for the strict delivery contract,
# but they do NOT prove live external delivery.
DATABASE_URL=file:./dev.db
HOST=127.0.0.1
PORT=18000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
KILL_SWITCH=false

# Local admin auth for strict checks
API_KEY=strict-local-key

# Make strict locally delivery-capable without relying on a real external publish target
PUBLISHER_MODE=webhook
PUBLISHER_WEBHOOK_URL=http://127.0.0.1:9999/mock-webhook
PUBLISHER_WEBHOOK_TOKEN=local-webhook-token

# Placeholder values that satisfy configured delivery capability checks
LLM_PROVIDER=openai
LLM_API_KEY=local-llm-placeholder
SEARCH_PROVIDER=serpapi
SEARCH_API_KEY=local-search-placeholder

# Keep native publish disabled in this profile
BILIBILI_ENABLED=false
BILIBILI_PUBLISH_ENABLED=false
BILIBILI_POLL_ENABLED=false

GATEWAY_TOKEN=local-gateway-token
GATEWAY_HMAC_SECRET=local-gateway-hmac-secret
